# Flask Configuration
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False

# JWT Configuration
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Password Reset Configuration
PASSWORD_RESET_SALT=replace-with-a-random-password-reset-salt
PASSWORD_RESET_EXPIRES_SECONDS=3600
EXPOSE_RESET_TOKEN=False
PASSWORD_RESET_FRONTEND_URL=https://your-frontend-domain/reset-password

# Email Configuration
MAIL_BACKEND=smtp
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=no-reply@yourdomain.com

# Database Configuration
# PostgreSQL format: postgresql://username:password@host:port/database
# Note: @ in password is URL-encoded as %40
DATABASE_URL=replace-with-your-production-database-url
DEV_DATABASE_URL=replace-with-your-development-database-url

# M-Pesa/Daraja API Configuration
DARAJA_CONSUMER_KEY=replace-with-daraja-consumer-key
DARAJA_CONSUMER_SECRET=replace-with-daraja-consumer-secret
DARAJA_SHORTCODE=your-business-shortcode
DARAJA_PASSKEY=your-DARAJA-passkey
DARAJA_CALLBACK_URL=https://yourdomain.com/confirm
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke

#QR Configuration
STATIC_QR_MODE=True

# Security Configuration
SESSION_COOKIE_SECURE=False
SESSION_LIFETIME=1800

# Customer Hash
CUSTOMER_HASH_SECRET=replace-with-customer-hash-secret
